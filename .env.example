# ============ CryptoWatcher — example config ============

# Source selector: BYBIT or CMC
PRICER=BYBIT

# Base settings
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
THRESHOLD_PERCENT=20
COOLDOWN_MIN=10
STATE_FILE=state_crypto_watcher.json

# Polling interval: 5m / 10m / 15m / 30m / 60m
POLL_INTERVAL=5m

# BYBIT settings
# Used only when PRICER=BYBIT
BYBIT_CATEGORY=spot
BYBIT_TOP_LIMIT=500
BYBIT_PAIRS=BTCUSDT,BNBUSDT,ETHUSDT,SOLUSDT,MNTUSDT

# Extra timeframe change shown in alerts/status for info only
SHOW_TF_CHANGE=1
CHANGE_TF=30m

# CMC settings
# Used only when PRICER=CMC
CMC_API_KEY=YOUR_CMC_API_KEY
CMC_TOP_LIMIT=0
WATCHLIST=BTC,BNB,ETH,SOL,MNT
CONVERT=USDT
