# ============================================================
# CryptoWatcher — example config
# ============================================================
# Copy this file to .env and fill in real values.
# Lines starting with # are comments.
# ============================================================

# ---------- Telegram ----------
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# Optional: comma-separated list of chat IDs allowed to use the bot.
# If empty or not set — bot is open to everyone.
# ALLOWED_CHAT_IDS=123456789,987654321

# ---------- Source selector ----------
# BYBIT or CMC
PRICER=BYBIT

# ---------- Alert logic ----------
# Threshold: alert fires when price moves this % from saved baseline.
THRESHOLD_PERCENT=20

# Cooldown between repeated alerts for the same symbol (minutes).
COOLDOWN_MIN=10

# ---------- Polling ----------
# How often each chat's prices are checked: 5m / 10m / 15m / 30m / 60m
POLL_INTERVAL=5m

# How often the engine loop ticks (seconds). Usually keep at 60.
ENGINE_INTERVAL_SEC=60

# ---------- State ----------
# Path inside the container. Must be under /data for Docker volume persistence.
STATE_FILE=/data/state_crypto_watcher.json

# Legacy fallback chat ID (used only for v1→v2 state migration).
# CHAT_ID=

# ---------- Bybit settings ----------
# Used only when PRICER=BYBIT
BYBIT_CATEGORY=spot
BYBIT_TOP_LIMIT=500
BYBIT_PAIRS=BTCUSDT,BNBUSDT,ETHUSDT,SOLUSDT,MNTUSDT

# Extra timeframe change shown in alerts/status (info only, not a trigger).
# Warning: with SHOW_TF_CHANGE=1 and large TOP_LIMIT, kline requests increase.
SHOW_TF_CHANGE=0
CHANGE_TF=30m

# ---------- CMC settings ----------
# Used only when PRICER=CMC
CMC_API_KEY=YOUR_CMC_API_KEY
CMC_TOP_LIMIT=0
WATCHLIST=BTC,BNB,ETH,SOL,MNT
CONVERT=USDT
